{
  "name": "nodebrains/theme",
  "description": "NodeBrains WordPress Theme — lightweight foundation for a proprietary visual page builder.",
  "type": "wordpress-theme",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "Swarnika Shakya",
      "email": "shakyaswarnika@gmail.com",
      "homepage": "https://nodebrains.com"
    }
  ],
  "require": {
    "php": ">=8.2"
  },
  "require-dev": {
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
    "phpcompatibility/phpcompatibility-wp": "^2.1",
    "squizlabs/php_codesniffer": "^3.10",
    "wp-coding-standards/wpcs": "^3.1"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "sort-packages": true
  },
  "scripts": {
    "phpcs": "phpcs",
    "phpcbf": "phpcbf",
    "lint:php": "phpcs --standard=phpcs.xml",
    "lint:php:fix": "phpcbf --standard=phpcs.xml"
  }
}
